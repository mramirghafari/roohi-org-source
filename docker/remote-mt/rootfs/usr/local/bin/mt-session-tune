#!/usr/bin/env bash
set -euo pipefail

export HOME=/config
export DISPLAY=${DISPLAY:-:1}

# Wait for XFCE session to come up, then trim non-essential UI pieces.
for _ in $(seq 1 30); do
  if pgrep -x xfce4-session >/dev/null 2>&1; then
    break
  fi
  sleep 1
done

# Enforce special desktop icon visibility off via xfconf at runtime.
if command -v xfconf-query >/dev/null 2>&1; then
  su -s /bin/bash abc -c "DISPLAY=${DISPLAY} xfconf-query -c xfce4-desktop -p /desktop-icons/file-icons/show-home -n -t bool -s false" >/dev/null 2>&1 || true
  su -s /bin/bash abc -c "DISPLAY=${DISPLAY} xfconf-query -c xfce4-desktop -p /desktop-icons/file-icons/show-filesystem -n -t bool -s false" >/dev/null 2>&1 || true
  su -s /bin/bash abc -c "DISPLAY=${DISPLAY} xfconf-query -c xfce4-desktop -p /desktop-icons/file-icons/show-trash -n -t bool -s false" >/dev/null 2>&1 || true
  su -s /bin/bash abc -c "DISPLAY=${DISPLAY} xfconf-query -c xfce4-desktop -p /desktop-icons/file-icons/show-removable -n -t bool -s false" >/dev/null 2>&1 || true
fi

pkill -x xfce4-panel >/dev/null 2>&1 || true
pkill -x dunst >/dev/null 2>&1 || true
pkill -x thunar-real >/dev/null 2>&1 || true
pkill -f thunar --daemon >/dev/null 2>&1 || true
pkill -x tumblerd >/dev/null 2>&1 || true
pkill -x xfce4-power-manager >/dev/null 2>&1 || true

# Keep Wine quieter and reduce useless background chatter.
export WINEDEBUG=-all
