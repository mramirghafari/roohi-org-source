#!/usr/bin/env bash
set -euo pipefail

export HOME=/config
export WINEPREFIX=/config/.wine
export WINEDEBUG=-all

CACHE_FILE=/config/.mt4-terminal-path

is_mt4_path() {
  local path="${1:-}"
  local lower
  local dir

  [[ -n "$path" && -f "$path" ]] || return 1
  lower="$(printf '%s' "$path" | tr '[:upper:]' '[:lower:]')"
  dir="$(dirname "$lower")"

  [[ "$dir" == *metatrader*4* || "$dir" == *"/mt4"* ]] || return 1
  [[ "$dir" == *metatrader*5* || "$dir" == *"/mt5"* ]] && return 1

  return 0
}

pick_first() {
  while IFS= read -r line; do
    if [[ -n "${line:-}" ]]; then
      echo "$line"
      return 0
    fi
  done
  return 1
}

find_mt4_path() {
  local base="$WINEPREFIX/drive_c"
  local candidate

  if [[ -f "$CACHE_FILE" ]]; then
    candidate="$(cat "$CACHE_FILE" 2>/dev/null || true)"
    if is_mt4_path "$candidate"; then
      echo "$candidate"
      return 0
    fi
  fi

  for candidate in \
    "$base/Program Files (x86)/MetaTrader 4/terminal.exe" \
    "$base/Program Files/MetaTrader 4/terminal.exe" \
    "$base/MetaTrader 4/terminal.exe" \
    "$base/Program Files (x86)/MetaTrader 4/terminal64.exe" \
    "$base/Program Files/MetaTrader 4/terminal64.exe"; do
    if is_mt4_path "$candidate"; then
      printf '%s\n' "$candidate" > "$CACHE_FILE"
      echo "$candidate"
      return 0
    fi
  done

  for dir in "$base/Program Files" "$base/Program Files (x86)" "$base"; do
    [[ -d "$dir" ]] || continue
    candidate="$(find "$dir" -type f \( -iname terminal.exe -o -iname terminal64.exe \) 2>/dev/null \
      | grep -Ei 'metatrader[^/]*4|/mt4' \
      | grep -Eiv 'metatrader[^/]*5|/mt5' \
      | pick_first || true)"
    if is_mt4_path "$candidate"; then
      printf '%s\n' "$candidate" > "$CACHE_FILE"
      echo "$candidate"
      return 0
    fi
  done

  candidate="$(find "$base" -type f \( -iname terminal.exe -o -iname terminal64.exe \) 2>/dev/null \
    | grep -Ei 'metatrader[^/]*4|/mt4' \
    | grep -Eiv 'metatrader[^/]*5|/mt5' \
    | pick_first || true)"
  if is_mt4_path "$candidate"; then
    printf '%s\n' "$candidate" > "$CACHE_FILE"
    echo "$candidate"
    return 0
  fi

  return 1
}

if command -v wine >/dev/null 2>&1; then
  WINE_BIN="$(command -v wine)"
elif command -v wine64 >/dev/null 2>&1; then
  WINE_BIN="$(command -v wine64)"
elif command -v wine32 >/dev/null 2>&1; then
  WINE_BIN="$(command -v wine32)"
elif [[ -x /usr/lib/wine/wine ]]; then
  WINE_BIN="/usr/lib/wine/wine"
elif [[ -x /usr/lib/wine/wine64 ]]; then
  WINE_BIN="/usr/lib/wine/wine64"
else
  command -v xmessage >/dev/null 2>&1 && xmessage -center "Wine runtime is missing in container."
  exit 1
fi

MT4_PATH="$(find_mt4_path || true)"

if [[ -z "${MT4_PATH:-}" ]]; then
  echo "MetaTrader 4 not found in Wine prefix: $WINEPREFIX" >&2
  command -v xmessage >/dev/null 2>&1 && xmessage -center "MT4 not installed for this user yet."
  exit 1
fi

exec "$WINE_BIN" "$MT4_PATH"
